//---{Config/{!ClassName!}GeneralConfig.cs}---
using System;
using MiniGamesSystem.MiniGames.Abstractions;
using MiniGamesSystem.MiniGames.Model;
using MiniGamesSystem.{!ClassName!}.Abstractions;
using Sirenix.OdinInspector;
using UnityEngine;
using Vortex.Core.Extensions.LogicExtensions;

#if UNITY_EDITOR
using Vortex.Unity.Extensions.Editor.Misc;
#endif

namespace MiniGamesSystem.{!ClassName!}.Config
{
    /// <summary>
    /// Основная конфигурация миниигры
    /// </summary>
    [CreateAssetMenu(fileName = "{!ClassName!}GeneralConfig", menuName = "Minigames/{!ClassName!} Game Config")]
    public class {!ClassName!}GeneralConfig : ScriptableObject, IMiniGameConfig
    {
        /// <summary>
        /// Контроллер игры
        /// </summary>
        [InfoBox(
            "Контроллер игры. Определяет логику и правила обработки данных.\nСкорее всего он будет только один, но возможность подмены есть")]
        [SerializeField, GUIColor("GuiColor"), ValueDropdown("GetControllers")]
        private string gameController;

        /// <summary>
        /// Контроллер игры
        /// </summary>
        public string GameController => gameController;

        /// <summary>
        /// Представление игры
        /// </summary>
        [InfoBox(
            "Визуальный вариант игры. Представление данных.\nСюда можно воткнуть MockUp")]
        [SerializeField]
        private GameObject view;

        /// <summary>
        /// Уровни сложности
        /// TODO решить нужны ли они и убрать при отсутствии необходимости
        /// </summary>
        [InfoBox("Уровни сложности игры и их названия (ключи для локализации)")]
        [OnValueChanged("OnLevelsChanged")]
        [SerializeField]
        private string[] levels = { "ease", "normal", "hard" };

        /// <summary>
        /// таймеры в зависимости от уровня сложности
        /// TODO решить нужны ли они и убрать при отсутствии необходимости
        /// </summary>
        [InfoBox("Время выделяемое на паззл в зависимости от уровня сложности игры")]
        [OnValueChanged("OnLevelsChanged")]
        [SerializeField]
        private int[] timers = { 60, 40, 20 };

        /// <summary>
        /// Размер игрового поля в зависимости от уровня сложности
        /// TODO решить нужны ли они и убрать при отсутствии необходимости
        /// </summary>
        [InfoBox("Размер игрового поля в зависимости от уровня сложности")]
        [OnValueChanged("OnLevelsChanged")]
        [SerializeField]
        private FieldSize[] fieldSize = { new(10, 10), new(7, 7), new(5, 5) };

        /// <summary>
        /// Представление игры
        /// </summary>
        /// <returns></returns>
        public GameObject GetView() => view;

        /// <summary>
        /// Возвращает название уровня сложности
        /// </summary>
        /// <param name="i"></param>
        /// <returns></returns>
        public string GetDifficulty(int i) => levels.Length > i ? levels[i] : null;

        /// <summary>
        /// Возвращает кол-во уровней сложности
        /// </summary>
        /// <returns></returns>
        public int GetDifficultiesCount() => levels.Length;

        /// <summary>
        /// Возвращает значение таймера для уровня сложности
        /// </summary>
        /// <param name="i"></param>
        /// <returns></returns>
        public int GetTimer(int i) => timers.Length > i ? timers[i] : throw new IndexOutOfRangeException();

        /// <summary>
        /// Возвращает размер поля для уровня сложности
        /// </summary>
        /// <param name="i"></param>
        /// <returns></returns>
        public FieldSize GetFieldSize(int i) =>
            fieldSize.Length > i ? fieldSize[i] : throw new IndexOutOfRangeException();

#if UNITY_EDITOR
        private bool _hasError = false;

        private Color GuiColor() => _hasError ? Color.red : Color.white;

        private ValueDropdownList<string> GetControllers() => DropDawnHandler.GetTypesNameList<I{!ClassName!}Controller>();

        private void OnValidate()
        {
            _hasError = false;
            if (gameController.IsNullOrWhitespace())
            {
                _hasError = true;
                return;
            }

            var type = Type.GetType(gameController);
            if (type == null)
            {
                _hasError = true;
                return;
            }

            if (!typeof(I{!ClassName!}Controller).IsAssignableFrom(type))
                _hasError = true;
        }

        private void OnLevelsChanged()
        {
            if (levels.Length == timers.Length && levels.Length == fieldSize.Length)
                return;

            var ar = new int[levels.Length];
            Array.Copy(timers, ar, Mathf.Min(timers.Length, levels.Length));
            timers = ar;

            var ar2 = new FieldSize[levels.Length];
            Array.Copy(fieldSize, ar2, Mathf.Min(fieldSize.Length, levels.Length));
            fieldSize = ar2;
        }
#endif
    }
}

//---{Controllers/{!ClassName!}Controller.cs}---
using MiniGamesSystem.MiniGames.Controllers;
using MiniGamesSystem.MiniGames.Model;
using MiniGamesSystem.{!ClassName!}.Abstractions;
using MiniGamesSystem.{!ClassName!}.Models;

namespace MiniGamesSystem.{!ClassName!}.Controllers
{
    /// <summary>
    /// Основной контроллер миниигры
    /// TODO Здесь нужно прописать основные действия с моделью данных.
    /// TODO Инициализация, проверка на победу и поражение, запрос на изменение данных. 
    /// </summary>
    public class {!ClassName!}Controller : MiniGameController<{!ClassName!}Controller, {!ClassName!}GameData>, I{!ClassName!}Controller
    {
        /// <summary>
        /// Инициализация контроллера.
        /// Создается экземпляр модели данных миниигры.
        /// Производится подписка на события приложения.
        /// </summary>
        public override void Init()
        {
            base.Init();
        }

        /// <summary>
        /// Деинициализация контроллера
        /// </summary>
        public override void DeInit()
        {
            Data.OnGameStateChanged -= OnStateLogic;
            base.DeInit();
        }

        public override void Play()
        {
            Data.StartTimer(OnTimerRunOut);
            Data.OnGameStateChanged -= OnStateLogic;
            Data.OnGameStateChanged += OnStateLogic;
            SetState(MiniGameStates.Play);
        }

        //TODO public void SetGameData(???)

        /// <summary>
        /// Проверка после истечения таймера и перевод игры в одно из двух положений
        /// </summary>
        private void OnTimerRunOut()
        {
            /*
            var result = TODO логика проверки;
            SetState(result ? MiniGameStates.Win : MiniGameStates.Fail);
            */
        }

        /// <summary>
        /// Вспомогательный обработчик изменения состояния.
        /// В идеале служит только для управления таймером при обработке паузы,
        /// так как остальные состояния должны проходить через контроллер и обрабатываться
        /// на момент их активации  
        /// </summary>
        /// <param name="state"></param>
        private void OnStateLogic(MiniGameStates state)
        {
            switch (state)
            {
                case MiniGameStates.Play:
                    Data.Timer.Resume();
                    break;
                case MiniGameStates.Off:
					Data.OnGameStateChanged -= OnStateLogic;
                    break;
                default:
                    if (!Data.Timer.IsComplete)
                        Data.Timer.SetPause();
                    break;
            }
        }
    }
}

