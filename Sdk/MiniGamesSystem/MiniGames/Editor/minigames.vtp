#if UNITY_EDITOR
using MiniGamesSystem.{!ClassName!}.Config;
using UnityEditor;
using UnityEngine;
using Vortex.Unity.EditorTools;

namespace MiniGamesSystem.{!ClassName!}.Editor
{
    /// <summary>
    /// Вспомогательный класс-tools для упрощения поиска ассета с настройками миниигры
    /// </summary>
    public static class {!ClassName!}GameMenuController
    {
        [MenuItem("Assets/Find Configs/{!ClassName!} Game")]
        private static void Find{!ClassName!}GameConfig()
        {
            var resource = AssetFinder.FindAsset<{!ClassName!}GeneralConfig>();
            FindAsset(resource);
        }

        private static void FindAsset(ScriptableObject res)
        {
            Selection.activeObject = res;
        }
    }
}
#endif

//---{Handler/{!ClassName!}StartHandler.cs}---
using UnityEngine;
using UnityEngine.UI;

namespace MiniGamesSystem.{!ClassName!}.Handler
{
    /// <summary>
    /// Хэндлер запуска миниигры в дебаг-режиме.
    /// Необходимость использования этого хэндлера определяется архитектурой
    /// взаимодействий элементов сцены
    /// </summary>
    public class {!ClassName!}StartHandler : MonoBehaviour
    {
        /// <summary>
        /// Кнопка, к которой привязывается хэндлер
        /// (опционально) 
        /// </summary>
        [SerializeField] private Button button;

        [SerializeField, Range(0, 2)] private byte hardness;

        private void OnEnable()
        {
            button?.onClick.AddListener(Play);
        }

        private void OnDisable()
        {
            button?.onClick.RemoveListener(Play);
        }

        /// <summary>
        /// Метод тестового запуска
        /// (то есть запуска с неполными данными)
        /// </summary>
        public void Play() => {!ClassName!}GameHub.DebugPlay(hardness);
    }
}

